    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Listar Usuarios",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var usuarios = pm.response.json();",
                  "function salvarId(email, chave) {",
                  "    var usuario = usuarios.find(function (item) { return item.email === email; });",
                  "    if (usuario) {",
                  "        pm.environment.set(chave, usuario.id);",
                  "    }",
                  "}",
                  "",
                  "salvarId(pm.environment.get('emailSindico'), 'usuarioIdSindico');",
                  "salvarId(pm.environment.get('emailPorteiro'), 'usuarioIdPorteiro');",
                  "salvarId(pm.environment.get('emailMorador'), 'usuarioIdMorador');",
                  "",
                  "if (pm.environment.get('usuarioIdPorteiro')) {",
                  "    pm.environment.set('usuarioIdAlvo', pm.environment.get('usuarioIdPorteiro'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{tokenAcessoAtual}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios"
              ]
            }
          },
          "response": []
