    {
      "name": "Setup",
      "item": [
        {
          "name": "Cadastrar Sindico",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 ou 409', function () {",
                  "    pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "",
                  "var json = {};",
                  "try { json = pm.response.json(); } catch (error) {}",
                  "",
                  "if (pm.response.code === 201 && json.id) {",
                  "    pm.environment.set('usuarioIdSindico', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
