    {
      "name": "Autenticacao",
      "item": [
        {
          "name": "Entrar como Sindico",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.environment.set('tokenSindico', json.token);",
                  "pm.environment.set('tokenAcessoAtual', json.token);",
                  "pm.environment.set('usuarioIdSindico', json.usuario.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{emailSindico}}\",\n  \"senha\": \"{{senhaSindico}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/autenticacao/entrar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "autenticacao",
                "entrar"
              ]
            }
          },
          "response": []
